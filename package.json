{
  "name": "votenaija",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev:api": "yarn workspace @votenaija/api dev",
    "dev:web": "yarn workspace @votenaija/web dev",
    "dev:mobile": "yarn workspace @votenaija/mobile start",
    "build:api": "bash scripts/deploy-api.sh",
    "build:web": "yarn workspace @votenaija/web build",
    "db:generate": "bash scripts/deploy-api.sh",
    "db:migrate": "yarn workspace @votenaija/database migrate",
    "db:seed": "yarn workspace @votenaija/database seed",
    "db:studio": "yarn workspace @votenaija/database studio",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "postinstall": "bash scripts/deploy-api.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "prisma": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
