# ============================================================
# VOTENAIJA — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- DATABASE ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/votenaija?schema=public"

# --- API SERVER ---
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
API_URL=http://localhost:4000

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# --- OTP ---
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6

# --- SMS PROVIDERS (6-Tier Fallback System) ---
# 1. SENDCHAMP (Primary)
SENDCHAMP_API_KEY=
SENDCHAMP_SENDER_ID=Sendchamp

# 2. TERMII (Fallback 1)
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=FameAfrica
TERMII_BASE_URL=https://api.ng.termii.com/api

# 3. SMARTSMS SOLUTIONS (Fallback 2)
SMARTSMS_API_KEY=
SMARTSMS_SENDER_ID=FameAfrica

# 4. AFRICA'S TALKING (Fallback 3)
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox

# 5. EBULKSMS (Fallback 4)
EBULKSMS_API_KEY=
EBULKSMS_EMAIL=
EBULKSMS_SENDER_ID=FameAfrica

# 6. ARKESEL (Fallback 5)
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=FameAfrica

# --- EMAIL (Resend) ---
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@votenaija.ng
EMAIL_FROM_NAME=VoteNaija

# --- PAYSTACK (Payments) ---
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# --- CLOUDINARY (File uploads & campaign cards) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- FRONTEND URLS ---
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- REDIS (for caching & rate limiting — optional for MVP) ---
REDIS_URL=redis://localhost:6379

# --- RATE LIMITING ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
VOTE_RATE_LIMIT_MAX=5

# --- ENCRYPTION (for sensitive data) ---
ENCRYPTION_KEY=your_32_char_encryption_key_here

# --- CRON ---
ELIMINATION_CRON_SCHEDULE="59 23 * * *"
VOTE_RESET_CRON_SCHEDULE="0 0 * * *"

# --- BLOCKCHAIN AUDITING ---
BLOCKCHAIN_CHAIN_ID=84532
BLOCKCHAIN_RPC_URL="https://sepolia.base.org"
BLOCKCHAIN_PRIVATE_KEY="d5aa361951f29e2a6b4e76aa0c32e4bcdea861a4877baf8e022d0960b1a8bd7d"